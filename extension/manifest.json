{
  "manifest_version": 3,
  "name": "NoteJet — Notes & Quizzes",
  "version": "1.0.0",
  "description": "Turn a screenshot or YouTube transcript into concise study notes and a quick quiz.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.notejet.app/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoteJet",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
